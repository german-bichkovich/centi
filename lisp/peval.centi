# (function:meta! list '((name . list)
#                        (inline . true)
#                        (pure . true)
#                        (type . (Function Any Any))
#                        (signiture . "(& args)")
#                        (documentation "Return a freshly allocated list of all given arguments")))
# 
# (meta:add! list 'name 'list)
# (meta:add! list 'inline true)
# (meta:add! list 'pure true)

(define Peval
  (special (form) env
    (peval form env)))

