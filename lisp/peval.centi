# -*- mode: scheme -*-
### Partial evaluator ################################################
# https://arxiv.org/pdf/2303.12254
# https://fexpr.blogspot.com/2013/07/explicit-evaluation.html

# Builtins have special partial evaluation rules
# Go into the function bodies recursively
# if pure and has no runtime dependancies, evaluate
# if not, return the form
# problems: fexprs, first class functions and side effects
# ? if constant, inline
# ? track if symbols are overridden?

(define peval-special-cases
  {+ (function (args env)
       (let ((static (apply + (list:filter number? args)))
             (dynamic (list:filter (compose not number?) args)))
         (if (pair? dynamic)
             (list:prepend '+ static dynamic)
             static)))
   quote (function ((arg) env)
           (if (or (pair? arg)
                   (symbol? arg))
               (list 'quote arg)
               arg))
   do (function (args env)
        (if (pair? (pair:tail args))
            (pair 'do args)
            (peval (pair:head args) env)))})

(define-function peval-arguments (args environment)
  (list:map (function (arg) (peval arg environment)) args))

# TODO
# Inlining
# Applying pure functions if form is complete (every argument is
#                                                    evaluated)
(define-function peval (form environment)
  (ifs ((symbol? form)
        (let ((e (environment:find environment form)))
          (if e
              (peval (list quote (evaluate form e))
                     environment)
              form)))
       ((pair? form)
        (let (((f . args) form)
              (f (peval f environment)))
          (ifs ((function? f)
                (ifs ((hashmap:get peval-special-cases f false)
                      ((hashmap:get peval-special-cases f)
                       (peval-arguments args environment)
                       environment))
                     (true
                      (pair f (peval-arguments args environment)))))
               ((special? f)
                (ifs ((hashmap:get peval-special-cases f false)
                      ((hashmap:get peval-special-cases f)
                       args
                       environment))
                     (true form)))
               (true
                (pair f (peval-arguments args environment))))))
       (true form)))

(let ((f function)
      (args '((x) x)))
  (peval (pair 'do (special::body f))
         (let ((e (environment (special::environment f))))
           (destructure (special::ptree f)
                        args
                        (function (k v) (environment:set! e k v)))
           e)))

