#!/bin/sh -e
# Centi build script.

# Start from CENTI_HOME
cd "$(dirname $(realpath "$0"))/.."

# Add $PWD to asdf load path
export CL_SOURCE_REGISTRY="$PWD"

# Build
sbcl --noinform <<- EOF
	(require :asdf)
	(asdf:disable-output-translations)
	(asdf:load-system :centi)
	(asdf:make :centi)
EOF

# Wrap the binary, setting CENTI_HOME if needed
{
	cat > ./bin/centi <<- EOF
		#!/bin/sh
		export CENTI_HOME="\${CENTI_HOME:-$PWD}"
		exec "\$CENTI_HOME/bin/.centi" "\$@"
	EOF
	chmod +x ./bin/centi
}

# Remove .fasl files
find -name '*.fasl' | xargs rm
